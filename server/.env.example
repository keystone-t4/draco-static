# Copy this file to ".env" (same folder) and fill in your real SMTP credentials.
# Never commit the real ".env" file — it is already excluded via .gitignore.
#
# Hostinger SMTP reference (Hostinger email accounts, e.g. info@dracofze.ae):
#   Host: smtp.hostinger.com
#   Port: 465 (SSL) or 587 (STARTTLS)
#   Username: the full mailbox address
#   Password: the mailbox password (set/reset it in hPanel > Emails)

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
# "ssl" for port 465, "tls" for port 587 (STARTTLS)
SMTP_ENCRYPTION=ssl
SMTP_USER=info@dracofze.ae
SMTP_PASS=change-me

# Envelope sender - usually the same mailbox as SMTP_USER
SMTP_FROM=info@dracofze.ae
SMTP_FROM_NAME=DRACO Website

# Where contact-form inquiries should be delivered
SMTP_TO=info@dracofze.ae
